{
  "name": "@topline/shared-do",
  "version": "0.1.0",
  "description": "LocationDO — per-tenant Cloudflare Durable Object with embedded SQLite storage for the synced data warehouse.",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "node --no-warnings --experimental-sqlite --import tsx --test src/parent-sync-state.test.ts"
  },
  "dependencies": {
    "@topline/shared-schema": "*"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240405.0",
    "@types/node": "^20.12.0",
    "tsx": "^4.21.0",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=22"
  }
}
