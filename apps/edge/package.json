{
  "name": "@topline-ai/edge",
  "version": "0.1.0",
  "description": "Topline OS MCP edge — stdio + Cloudflare Worker entry points.",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc --noEmit && esbuild src/index.ts --bundle --platform=node --target=node20 --format=esm --outfile=dist/index.js --banner:js=\"#!/usr/bin/env node\"",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "worker:dev": "wrangler dev",
    "worker:deploy": "wrangler deploy",
    "worker:typecheck": "tsc --noEmit -p tsconfig.worker.json",
    "pretest": "npm run build --workspace=@topline/shared --workspace=@topline/shared-auth --workspace=@topline/shared-schema --workspace=@topline/shared-do",
    "test": "tsx --test src/sql-safety.test.ts src/write-tools.test.ts src/composite.test.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@topline/shared": "*",
    "@topline/shared-auth": "*",
    "@topline/shared-do": "*",
    "@topline/shared-schema": "*",
    "node-sql-parser": "^5.4.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240405.0",
    "@types/node": "^20.12.0",
    "esbuild": "^0.28.0",
    "tsx": "^4.21.0",
    "typescript": "^5.4.0",
    "wrangler": "^3.60.0"
  },
  "engines": {
    "node": ">=22"
  }
}
