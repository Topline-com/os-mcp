{
  "name": "@topline-ai/mcp",
  "version": "0.1.0",
  "description": "Topline MCP — drive your Topline sub-account from Claude.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "topline-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "prepare": "npm run build",
    "prepublishOnly": "npm run build",
    "worker:dev": "wrangler dev",
    "worker:deploy": "wrangler deploy",
    "worker:typecheck": "tsc --noEmit -p tsconfig.worker.json"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240405.0",
    "@types/node": "^20.12.0",
    "typescript": "^5.4.0",
    "wrangler": "^3.60.0"
  },
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/topline-com/os-mcp.git"
  }
}
